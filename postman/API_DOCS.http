### LOGOUT A USER
# @Module: AUTH APIS
# @Description: Invalidates the user's current session and refresh token.
POST {{baseUrl}}/api/auth/logout
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "refreshToken": "{{refreshToken}}"
}

# STATUS CODE 200 (Success - Tokens invalidated and cookies cleared)
# RESPONSE BODY
# {
#   "status": "success",
#   "code": 200,
#   "message": "Logged out successfully",
#   "data": null,
#   "record_count": 0,
#   "errors": [],
#   "timestamp": "2026-03-13T08:08:21.094Z",
#   "request_id": "5c219b80..."
# }

# STATUS CODE 200 (Idempotent - Already logged out or missing refresh token)
# RESPONSE BODY
# {
#   "status": "success",
#   "code": 200,
#   "message": "Logged out successfully",
#   "data": null,
#   "record_count": 0,
#   "errors": [],
#   "timestamp": "2026-03-13T08:08:21.094Z",
#   "request_id": "5c219b80..."
# }

# STATUS CODE 401 (Unauthorized - Bearer token missing or invalid)
# RESPONSE BODY
# {
#   "status": "error",
#   "code": 401,
