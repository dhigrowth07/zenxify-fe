Authorization: Bearer {{authToken}}

# STATUS CODE 200 (Success)

### DELETE MULTIPLE NOTIFICATIONS
# @Module: NOTIFICATION APIS
# @Description: Removes a selection of notifications using an array of IDs.
DELETE {{baseUrl}}/api/notifications/bulk
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "ids": ["9285d85f-d9d2-49a5-8e89-eeb5de6d30bd", "ec37fe15-062a-4284-8224-2d55ccda0df0"]
}

# STATUS CODE 200 (Success)

### DELETE ALL NOTIFICATIONS
# @Module: NOTIFICATION APIS
# @Description: Clears the entire notification box for the authenticated user.
DELETE {{baseUrl}}/api/notifications/all
Authorization: Bearer {{authToken}}

# STATUS CODE 200 (Success)

### NOTIFICATION STREAM (SSE)
# @Module: NOTIFICATION APIS
# @Description: Real-time Server-Sent Events stream for notifications.
GET {{baseUrl}}/api/notifications/stream
Authorization: Bearer {{authToken}}
Accept: text/event-stream


