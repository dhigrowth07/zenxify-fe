### UPDATE PLAN
# @Module: ADMIN PLANS
# @Description: Updates plan features, pricing, or limits.
PATCH {{baseUrl}}/api/admin/plans/pro
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "monthly_credits": 1000,
    "features": {
        "export_8k": true
    },
    "storage_quota_gb": 50
}

# STATUS CODE 200 (Success)
# RESPONSE BODY
# {
#   "status": "success",
#   "code": 200,
#   "message": "Plan 'pro' updated successfully",
#   "data": { "plan": { ... } }
# }

### LIST ALL TOP-UP PACKS
# @Module: ADMIN PLANS
# @Description: Retrieves all credit top-up packs.
GET {{baseUrl}}/api/admin/plans/top-ups/all
Authorization: Bearer {{authToken}}

# STATUS CODE 200 (Success)

### UPDATE TOP-UP PACK
# @Module: ADMIN PLANS
# @Description: Updates price or credit amount for a specific pack.
PATCH {{baseUrl}}/api/admin/plans/top-ups/starter
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
    "price_inr": 599,
    "credits": 500
}

# STATUS CODE 200 (Success)
